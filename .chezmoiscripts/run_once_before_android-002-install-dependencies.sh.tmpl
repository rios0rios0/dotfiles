# =========================================================================================================
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# https://ohmyz.sh/#install
install_oh_my_zsh() {
    omzPath="$HOME/.oh-my-zsh"

    if [ ! -d "$omzPath" ]; then
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    else
        echo "Oh My ZSH is already installed."
    fi
}

# GVM is intentionally SKIPPED on Android/Termux.
# GVM installs standard linux/arm64 Go builds that use the faccessat2 syscall (439),
# which is blocked by Android's seccomp filter, causing "SIGSYS: bad system call".
# The Termux-native Go package (apt install golang) builds with GOOS=android and
# avoids blocked syscalls. Always use the Termux package on Android.
#
# https://github.com/moovweb/gvm?tab=readme-ov-file
install_gvm() {
    echo "GVM skipped on Android/Termux (standard Go builds crash due to seccomp; use Termux's native package)."
}

install_termux_etc_redirect() {
  sourcePath="$HOME/Development/github.com/rios0rios0/termux-etc-redirect"
  mkdir -p "$(dirname "$sourcePath")"
  if [ ! -d "$sourcePath" ]; then
      git clone https://github.com/rios0rios0/termux-etc-redirect.git "$sourcePath"
  fi

  # Run in a subshell to avoid changing the script's working directory
  (
    cd "$sourcePath" && git fetch --all && git pull --rebase

    # Build, install, and create missing config files (resolv.conf, nsswitch.conf)
    ./scripts/install.sh
  )
}

# github.com/rios0rios0/terra
# https://terragrunt.gruntwork.io/docs/getting-started/install/
# https://developer.hashicorp.com/terraform/install
install_terra() {
    # TODO: can't avoid repetition?
    binPath="$HOME/.local/bin"
    terraBin="$binPath/terra"

    if [ ! -f "$terraBin" ]; then
        sourcePath="$HOME/Development/github.com/rios0rios0/terra"
        if [ ! -d "$sourcePath" ]; then
            git clone https://github.com/rios0rios0/terra.git "$sourcePath"
        fi
        cd "$sourcePath" && git fetch --all && git pull --rebase

        make install
    else
        echo "Terra is already installed."
    fi

    terra update
}

# https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/
install_kubectl() {
    binPath="$HOME/.local/bin"
    kubectlBin="$binPath/kubectl"

    if [ ! -f "$kubectlBin" ]; then
        curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/arm64/kubectl"
        mv kubectl "$kubectlBin"
        chmod +x "$kubectlBin"
    else
        echo "Kubectl is already installed."
    fi
}

# https://sdkman.io/install/
install_sdkman() {
    sdkPath="$HOME/.sdkman"

    if [ ! -d "$sdkPath" ]; then
        curl -s "https://get.sdkman.io" | bash

        # shellcheck disable=SC1091
        source "$sdkPath/bin/sdkman-init.sh"
        sdk install java
        sdk install gradle
    else
        echo "SDKMan is already installed."
    fi
}

# https://github.com/nvm-sh/nvm?tab=readme-ov-file#install--update-script
install_nvm() {
    if command_exists npm; then
        echo "Node detected, means it was previously installed or native package installed..."

        npm install -g corepack
        corepack enable
        return;
    fi

    nvmPath="$HOME/.nvm"

    if [ ! -d "$nvmPath" ]; then
        curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash

        unset PREFIX
        # shellcheck disable=SC1091
        source "$nvmPath/nvm.sh"
        nvm install --lts

        npm install -g npm@latest
        npm install -g corepack
        corepack enable
    else
        echo "NVM is already installed."
    fi
}

# https://github.com/pyenv/pyenv
install_pyenv() {
    if command_exists pip; then
        echo "Python detected, means it was previously installed or native package installed..."

        return;
    fi

    pyenvPath="$HOME/.pyenv"

    if [ ! -d "$pyenvPath" ]; then
        curl -fsSL https://pyenv.run | bash

        export PATH="$PATH:$pyenvPath"
        pyenv install 3.13:latest
        pyenv global 3.13:latest

        pip install --upgrade pip
    else
        echo "Pyenv is already installed."
    fi
}

# https://github.com/google-gemini/gemini-cli
install_gemini_cli() {
    npm install -g @google/gemini-cli
}

# https://github.com/anthropics/claude-code
install_claude_cli() {
    npm install -g @anthropic-ai/claude-code
}

# https://github.com/rios0rios0/devforge
install_devforge() {
    binPath="$HOME/.local/bin"
    devBin="$binPath/dev"

    if [ ! -f "$devBin" ]; then
        local installer
        installer="$(mktemp)"
        if ! curl -fsSL https://raw.githubusercontent.com/rios0rios0/devforge/main/install.sh -o "$installer"; then
            echo "[devforge] ERROR: failed to download installer" >&2
            rm -f "$installer"
            return 1
        fi
        bash "$installer"
        local status=$?
        rm -f "$installer"
        if [ "$status" -ne 0 ]; then return "$status"; fi
    else
        echo "Devforge is already installed."
    fi
}

# https://1password.com/downloads/command-line/
install_1password_cli() {
    binPath="$HOME/.local/bin"
    opBin="$binPath/op_linux_arm64"

    if [ ! -f "$opBin" ]; then
        ARCH="arm64"
        wget "https://cache.agilebits.com/dist/1P/op2/pkg/v2.31.1/op_linux_${ARCH}_v2.31.1.zip" -O op.zip
        unzip -d op op.zip
        mv op/op "$opBin"
        chmod +x "$opBin"
        rm -rf op.zip op
    else
        echo "1Password CLI is already installed."
    fi
}

# https://cli.github.com/manual/installation
install_github_cli() {
    binPath="$HOME/.local/bin"
    ghBin="$binPath/gh_linux_arm64"

    if [ ! -f "$ghBin" ]; then
        GH_VERSION="2.67.0"
        ARCH="linux_arm64"
        wget "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_${ARCH}.tar.gz" -O gh.tar.gz
        tar -xzf gh.tar.gz
        mv "gh_${GH_VERSION}_${ARCH}/bin/gh" "$ghBin"
        chmod +x "$ghBin"
        rm -rf gh.tar.gz "gh_${GH_VERSION}_${ARCH}"
    else
        echo "GitHub CLI is already installed."
    fi
}

# https://github.com/github/gh-copilot
install_github_copilot() {
    extensionsDir="$HOME/.local/share/gh/extensions"

    if [ -d "$extensionsDir/gh-copilot" ]; then
        echo "GitHub Copilot CLI is already installed."
        return
    fi

    echo "[gh-copilot] installing GitHub Copilot extension (best-effort)..." >&2
    # gh extension install requires authentication; skip gracefully if not authed
    if ~/.local/bin/gh auth status &>/dev/null; then
        ~/.local/bin/gh extension install github/gh-copilot || {
            echo "[gh-copilot] WARN: extension install failed, skipping" >&2
        }
    else
        echo "[gh-copilot] WARN: gh not authenticated, skipping copilot extension install" >&2
    fi
}

# https://golangci-lint.run/welcome/install/
install_golangci_lint() {
    binPath="$HOME/.local/bin"
    golangciBin="$binPath/golangci-lint_linux_arm64"

    if [ ! -f "$golangciBin" ]; then
        GLC_VERSION="2.11.4"
        ARCH="linux-arm64"

        (
            tmpDir="$(mktemp -d)" || {
                echo "[golangci-lint] ERROR: failed to create temporary directory" >&2
                exit 1
            }

            trap 'rm -rf "$tmpDir"' EXIT
            cd "$tmpDir" || exit

            wget "https://github.com/golangci/golangci-lint/releases/download/v${GLC_VERSION}/golangci-lint-${GLC_VERSION}-${ARCH}.tar.gz" -O golangci-lint.tar.gz
            tar -xzf golangci-lint.tar.gz
            mv "golangci-lint-${GLC_VERSION}-${ARCH}/golangci-lint" "$golangciBin"
            chmod +x "$golangciBin"
        )
    else
        echo "golangci-lint is already installed."
    fi
}

# https://pypi.org/project/azure-cli/
install_azure_cli() {
    if ! command_exists pip; then
        echo "Install 'pip' first, it seems to be NOT installed..."

        return;
    fi

    azPath="$HOME/.azure"

    if [ ! -d "$azPath" ]; then
        # TODO: when installed via Pyenv it should be loaded first on the current shell
        pip install azure-cli
        az extension add --name azure-devops
    else
        echo "AZ is already installed."
    fi
}

install_oh_my_zsh

