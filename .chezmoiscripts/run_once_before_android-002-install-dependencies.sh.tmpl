# https://1password.com/downloads/command-line/
install_1password_cli() {
    binPath="$HOME/.local/bin"
    opBin="$binPath/op_linux_arm64"

    if [ ! -f "$opBin" ]; then
        ARCH="arm64"
        wget "https://cache.agilebits.com/dist/1P/op2/pkg/v2.31.1/op_linux_${ARCH}_v2.31.1.zip" -O op.zip
        unzip -d op op.zip
        mv op/op "$opBin"
        chmod +x "$opBin"
        rm -rf op.zip op
    else
        echo "1Password CLI is already installed."
    fi
}

# https://cli.github.com/manual/installation
install_github_cli() {
    binPath="$HOME/.local/bin"
    ghBin="$binPath/gh_linux_arm64"

    if [ ! -f "$ghBin" ]; then
        GH_VERSION="2.67.0"
        ARCH="linux_arm64"
        wget "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_${ARCH}.tar.gz" -O gh.tar.gz
        tar -xzf gh.tar.gz
        mv "gh_${GH_VERSION}_${ARCH}/bin/gh" "$ghBin"
        chmod +x "$ghBin"
        rm -rf gh.tar.gz "gh_${GH_VERSION}_${ARCH}"
    else
        echo "GitHub CLI is already installed."
    fi
}

# https://github.com/github/gh-copilot
install_github_copilot() {
    extensionsDir="$HOME/.local/share/gh/extensions"

    if [ -d "$extensionsDir/gh-copilot" ]; then
        echo "GitHub Copilot CLI is already installed."
        return
    fi

    echo "[gh-copilot] installing GitHub Copilot extension (best-effort)..." >&2
    # gh extension install requires authentication; skip gracefully if not authed
    if ~/.local/bin/gh auth status &>/dev/null; then
        ~/.local/bin/gh extension install github/gh-copilot || {
            echo "[gh-copilot] WARN: extension install failed, skipping" >&2
        }
    else
        echo "[gh-copilot] WARN: gh not authenticated, skipping copilot extension install" >&2
    fi
}

# https://golangci-lint.run/welcome/install/
install_golangci_lint() {
    binPath="$HOME/.local/bin"
    golangciBin="$binPath/golangci-lint_linux_arm64"

    if [ ! -f "$golangciBin" ]; then
        GLC_VERSION="2.11.4"
        ARCH="linux-arm64"

        (
            tmpDir="$(mktemp -d)" || {
                echo "[golangci-lint] ERROR: failed to create temporary directory" >&2
                exit 1
            }

            trap 'rm -rf "$tmpDir"' EXIT
            cd "$tmpDir" || exit

            wget "https://github.com/golangci/golangci-lint/releases/download/v${GLC_VERSION}/golangci-lint-${GLC_VERSION}-${ARCH}.tar.gz" -O golangci-lint.tar.gz
            tar -xzf golangci-lint.tar.gz
            mv "golangci-lint-${GLC_VERSION}-${ARCH}/golangci-lint" "$golangciBin"
            chmod +x "$golangciBin"
        )
    else
        echo "golangci-lint is already installed."
    fi
}

# https://developer.atlassian.com/cloud/acli/guides/install-linux/
# Atlassian only publishes a rolling `latest` endpoint (no versioned URLs, no checksums/signatures),
# so pinning or cryptographic verification is not possible upstream; the install tracks the latest
# stable channel officially recommended by Atlassian.
install_acli() {
    binPath="$HOME/.local/bin"
    acliBin="$binPath/acli_linux_arm64"

    if [ ! -f "$acliBin" ]; then
        (
            tmpDir="$(mktemp -d)" || {
                echo "[acli] ERROR: failed to create temporary directory" >&2
                exit 1
            }

            trap 'rm -rf "$tmpDir"' EXIT
            cd "$tmpDir" || exit 1

            wget "https://acli.atlassian.com/linux/latest/acli_linux_arm64.tar.gz" -O acli.tar.gz
            # The archive nests the binary under `acli_<version>-stable_linux_arm64/acli`,
            # so strip the versioned top-level directory to extract the binary directly.
            tar -xzf acli.tar.gz --strip-components=1
            mv acli "$acliBin"
            chmod +x "$acliBin"
        )
    else
        echo "[acli] acli is already installed, skipping" >&2
    fi
}

# https://github.com/aws/aws-cli/tree/v2
# Termux can't use the official aws-cli aarch64 bundle (glibc-linked; Termux is bionic),
# so we build from source. `cmake`, `rust`, `clang`, and `make` in the deps above provide
# the toolchain needed to compile `awscrt`.
install_aws_cli() {
    if ! command_exists pip; then
        echo "Install 'pip' first, it seems to be NOT installed..."

        return;
    fi

    if command_exists aws && aws --version 2>&1 | grep -q "aws-cli/2\."; then
        echo "AWS CLI v2 is already installed."
        return
    fi

    echo "[aws-cli] building AWS CLI v2 from source (10-15 min on ARM64)..." >&2

    (
        tmpDir="$(mktemp -d)" || {
            echo "[aws-cli] ERROR: failed to create temporary directory" >&2
            exit 1
        }

        trap 'rm -rf "$tmpDir"' EXIT
        cd "$tmpDir" || exit 1

        git clone --depth 1 -b v2 https://github.com/aws/aws-cli.git
        cd aws-cli || exit 1

        pip install --upgrade pip

        # `awscrt` bundles a libcrypto that still calls `FIPS_mode` — removed in OpenSSL 3.x,
        # which is what Termux ships (3.6+). Link against the system libcrypto and force a
        # source build so the wheel cached under the `android_*` platform tag is regenerated.
        AWS_CRT_BUILD_USE_SYSTEM_LIBCRYPTO=1 PIP_NO_BINARY=awscrt pip install .
    )
}

# https://pypi.org/project/azure-cli/
install_azure_cli() {
    if ! command_exists pip; then
        echo "Install 'pip' first, it seems to be NOT installed..."

        return;
    fi

    # Check the actual package, not `~/.azure`: that directory is created by `az`
    # at runtime for config/profile storage and can exist without azure-cli installed
    # (e.g., left over from a prior uninstall), causing the install to be skipped forever.
    if pip show azure-cli &>/dev/null; then
        echo "AZ is already installed."
        return
    fi

    # Python 3.13 on Termux reports `sys.platform == "android"`, which psutil's setup.py
    # rejects with "platform android is not supported". Pre-install a patched copy (the
    # same one-line _common.py fix from termux-packages PR #28780) so pip sees psutil>=5.9
    # already satisfied when resolving `azure-cli` dependencies. Reinstall the patched
    # version when psutil is missing or does not match the intended release, otherwise
    # pip may still attempt to resolve/upgrade psutil and hit the same Android refusal.
    local psutilVer="7.2.2"
    local installedPsutilVer=""
    if pip show psutil &>/dev/null; then
        installedPsutilVer="$(pip show psutil 2>/dev/null | sed -n 's/^Version: //p' | head -n1)"
    fi

    if [ "$installedPsutilVer" != "$psutilVer" ]; then
        (
            psutilDir="$(mktemp -d)" || {
                echo "[azure-cli] ERROR: failed to create psutil build dir" >&2
                exit 1
            }

            trap 'rm -rf "$psutilDir"' EXIT
            cd "$psutilDir" || exit 1

            curl -fsSL "https://github.com/giampaolo/psutil/archive/refs/tags/release-${psutilVer}.tar.gz" -o psutil.tar.gz
            tar -xzf psutil.tar.gz
            cd "psutil-release-${psutilVer}" || exit 1

            sed -i 's|sys.platform.startswith("linux")|sys.platform.startswith(("linux", "android"))|' psutil/_common.py
            if ! grep -Fq 'sys.platform.startswith(("linux", "android"))' psutil/_common.py; then
                echo "[azure-cli] ERROR: failed to patch psutil/_common.py for Android; upstream source no longer matches the expected linux-only platform check" >&2
                exit 1
            fi
            pip install .
        )
    fi

    # PyNaCl's bundled libsodium `make` invocation fails on Termux. Termux ships
    # `libsodium` in apt (see deps above); SODIUM_INSTALL=system links against it
    # instead, and pip propagates the env var into its build-isolation subprocess.
    # TODO: when installed via Pyenv it should be loaded first on the current shell
    SODIUM_INSTALL=system pip install azure-cli
    az extension add --name azure-devops
}

