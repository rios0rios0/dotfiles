# define the path to the .ssh folder
$sshFolderPath = "$HOME\.ssh"

# ensure the .ssh folder exists
if (-Not (Test-Path -Path $sshFolderPath)) {
    New-Item -ItemType Directory -Path $sshFolderPath
}

{{- $deviceName := .deviceName -}}

{{- warnf "[windows-ssh-keys] fetching Active SSHs...\n" -}}
{{- range (onepassword "Active SSHs" "personal" "my").fields }}
{{-      if (eq .type "REFERENCE") }}

{{-        $item := onepassword .value "Private" "my" -}}
{{-        $sshName := $item.title | trim -}}
{{-        warnf "[windows-ssh-keys] checking SSH item \"%s\"...\n" $sshName -}}
{{-        $parts := split "@" $sshName -}}
{{-        $device := index $parts "_0" -}}

{{-        if eq $device $deviceName }}
{{-        warnf "[windows-ssh-keys] creating public key for \"%s\"\n" $sshName -}}

# read the SSH public key from 1Password
$sshName = "{{ $sshName }}"
{{- $f := dict -}}
{{- range $item.fields -}}
  {{- $_ := set $f .label .value -}}
{{- end }}
$sshPublicKey = "{{ index $f "public key" }}"

# create the public key file
$publicKeyFilePath = "$sshFolderPath\$sshName.pub"
Write-Output "Creating public key file: `"$publicKeyFilePath`"..."
Set-Content -Path $publicKeyFilePath -Value $sshPublicKey -Force

{{-        end -}}
{{-      end -}}
{{- end }}
