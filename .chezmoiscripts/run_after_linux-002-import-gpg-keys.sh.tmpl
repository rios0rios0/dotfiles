#!/bin/bash

set -euo pipefail

# define the path to the ".gpg" folder
gpgFolderPath="$HOME/.gpg"

# ensure the ".gpg" folder exists
mkdir -p $gpgFolderPath

{{- warnf "[linux-gpg-keys] fetching Active GPGs..." -}}
{{- $gpgNotes := "" -}}
{{- range (onepassword "Active GPGs" "personal" "my").fields -}}
  {{- if and (eq .label "notesPlain") (hasKey . "value") -}}
    {{- $gpgNotes = .value -}}
  {{- end -}}
{{- end -}}
{{- range splitList "\n" $gpgNotes }}
{{-      $title := . | trim -}}
{{-      if ne $title "" }}

# read the GPG name and private key from 1Password
{{- $item := onepassword $title "Private" "my" -}}
{{- warnf "[linux-gpg-keys] importing GPG key \"%s\"" $item.title -}}
{{- $f := dict -}}
{{- range $item.fields -}}
  {{- if hasKey . "value" -}}
    {{- $_ := set $f .label .value -}}
  {{- end -}}
{{- end }}
{{- $gpgPassword := "" -}}
{{- if hasKey $f "password" -}}
  {{- $gpgPassword = trimAll "`" (index $f "password") -}}
{{- end -}}
{{- $gpgPrivateKey := onepasswordRead (printf "op://Private/%s/private.key" $item.id) "my" }}
gpgName="{{ $item.title }}"
gpgPassword="{{ $gpgPassword }}"
gpgPrivateKey="{{ trimAll "`" $gpgPrivateKey }}"

# create the private key file
privateKeyFilePath="$gpgFolderPath/$gpgName"
echo "[linux-gpg-keys] creating private key: \"$privateKeyFilePath\"" >&2
echo "$gpgPrivateKey" > "$privateKeyFilePath"

# import GPG keys into GPG keyring
gpg --batch --passphrase "$gpgPassword" --import "$privateKeyFilePath"

echo "[linux-gpg-keys] importing into GPG keyring..." >&2

{{-      end -}}
{{- end }}

# cleanup the ".gpg" folder
rm -rf $gpgFolderPath
