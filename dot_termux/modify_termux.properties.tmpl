#!{{ lookPath "bash" }}

# This modify_ script patches only managed keys in termux.properties,
# preserving the rest of the file (comments, defaults, future Termux additions).

echo "[termux-config] configuring termux properties" >&2

export DESIRED
DESIRED="$(cat <<'KEYS'
extra-keys = [['ESC','/','-','HOME','UP','END','PGUP'], \
              ['TAB','CTRL','SHIFT','LEFT','DOWN','RIGHT','PGDN']]
KEYS
)"

contents="$(cat)"

# Replace existing uncommented extra-keys line(s) (including continuation lines) in-place
result="$(echo "$contents" | awk '
  /^extra-keys[[:space:]]*=/ {
    while (/\\$/) {
      if ((getline) <= 0) break
    }
    print ENVIRON["DESIRED"]
    next
  }
  { print }
')"

# If no extra-keys line existed, append it
if ! echo "$result" | grep -q "^extra-keys[[:space:]]*="; then
  result="$(printf '%s\n%s' "$result" "$DESIRED")"
fi

# Set single-line key=value properties (replace if uncommented, append if absent)
set_property() {
  local key="$1" value="$2" key_escaped
  # Escape regex metacharacters in key for safe use in grep/sed patterns
  key_escaped="$(printf '%s\n' "$key" | sed 's/[][\\.^$*+?{}()|]/\\&/g')"
  if printf '%s\n' "$result" | grep -q "^${key_escaped}[[:space:]]*="; then
    result="$(printf '%s\n' "$result" | sed "s|^${key_escaped}[[:space:]]*=.*|${key} = ${value}|")"
  else
    result="$(printf '%s\n%s' "$result" "${key} = ${value}")"
  fi
}

set_property "terminal-transcript-rows" "5000"
set_property "bell-character" "ignore"
set_property "terminal-cursor-blink-rate" "0"

printf '%s\n' "$result"
