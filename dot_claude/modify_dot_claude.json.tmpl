#!{{ lookPath "bash" }}
# Patches hasTrustDialogAccepted into ~/.claude/.claude.json
# Receives current file content on stdin, outputs desired content on stdout.

_script="$(mktemp)"
trap 'rm -f "$_script"' EXIT
cat > "$_script" << 'PYEOF'
import json, os, sys

current = sys.stdin.read().strip()

if current:
    try:
        data = json.loads(current)
    except json.JSONDecodeError:
        data = {}
else:
    data = {}

projects = data.setdefault("projects", {})
dev_base = os.path.expanduser("~/Development/github.com/rios0rios0")

# Trust home dir and dev base
trust_dirs = [os.path.expanduser("~"), dev_base]

# Auto-discover project subdirectories
if os.path.isdir(dev_base):
    for entry in os.listdir(dev_base):
        full = os.path.join(dev_base, entry)
        if os.path.isdir(full):
            trust_dirs.append(full)

for d in trust_dirs:
    proj = projects.setdefault(d, {})
    proj["hasTrustDialogAccepted"] = True

json.dump(data, sys.stdout, indent=2)
sys.stdout.write("\n")
PYEOF
python3 "$_script"
