{{- $deviceName := .deviceName -}}
{
  "auths": {
    {{- warnf "[docker-config] fetching Device: %s..." $deviceName }}
    {{- $deviceNotes := "" }}
    {{- range (onepassword (printf "Device: %s" $deviceName) "personal" "my").fields }}
    {{-   if and (eq .label "notesPlain") (hasKey . "value") }}
    {{-     $deviceNotes = .value }}
    {{-   end }}
    {{- end }}
    {{- $first := true }}
    {{- range splitList "\n" $deviceNotes }}
    {{-   $entry := . | trim }}
    {{-   if ne $entry "" }}
    {{-     $type := index (split ":" $entry) "_0" }}
    {{-     $name := trimPrefix (printf "%s:" $type) $entry | trim }}
    {{-     if eq $type "docker" }}
    {{-       $opItem := onepassword $name "Private" "my" }}
    {{-       $f := dict }}
    {{-       range $opItem.fields }}
    {{-         if hasKey . "value" }}
    {{-           $_ := set $f .label .value }}
    {{-         end }}
    {{-       end }}
    {{-       $registryUsername := "" }}
    {{-       if hasKey $f "username" }}{{ $registryUsername = trim (index $f "username") }}{{ end }}
    {{-       $registryCredential := "" }}
    {{-       if hasKey $f "credential" }}{{ $registryCredential = trim (index $f "credential") }}{{ end }}
    {{-       $registryName := "" }}
    {{-       if hasKey $f "registry name" }}{{ $registryName = trim (index $f "registry name") }}{{ end }}
    {{-       if eq $registryName "" }}{{ $registryName = $opItem.title }}{{ end }}
    {{-       $identityToken := "" }}
    {{-       if hasKey $f "identitytoken" }}
    {{-         $identityToken = trim (index $f "identitytoken") }}
    {{-       end }}
    {{-       $hasIdentityToken := ne $identityToken "" }}
    {{-       if and $hasIdentityToken (eq $registryUsername "") }}
    {{-         $registryUsername = "00000000-0000-0000-0000-000000000000" }}
    {{-       end }}
    {{-       $hasAuth := and (ne $registryUsername "") (ne $registryCredential "") }}
    {{-       if or $hasAuth $hasIdentityToken }}
    {{-         warnf "[docker-config] configuring registry \"%s\"" $registryName }}
    {{- if not $first }},{{ end }}
    "{{ $registryName }}": {
    {{- if $hasIdentityToken }}
      "auth": "{{ b64enc (list $registryUsername ":" $registryCredential | join "") }}",
      "identitytoken": "{{ $identityToken }}"
    {{- else }}
      "auth": "{{ b64enc (list $registryUsername ":" $registryCredential | join "") }}"
    {{- end }}
    }
    {{-         $first = false }}
    {{-       else }}
    {{-         warnf "[docker-config] WARN: skipping registry \"%s\" because neither valid auth nor identitytoken is available" $registryName }}
    {{-       end }}
    {{-     end }}
    {{-   end }}
    {{- end }}
  }
}
