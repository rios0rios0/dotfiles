{{- /* TODO: when the Windows username is different than WSL username, the 1Password path is different breaking the commit signing */ -}}
{{- $deviceName := .deviceName -}}
{{- $username := include "username.tmpl" . | trim }}

{{- /* OS-dependent paths and executables */ -}}
{{- $windowsHome := printf "C:/Users/%s" $username -}}
{{- $defaultHome := .chezmoi.homeDir -}}

{{- $program := "op-ssh-sign" -}}
{{- $allowedSignersFile := printf "%s/.ssh/allowed_signers" $defaultHome -}}
{{- $excludesFile := printf "%s/.gitignore" $defaultHome -}}
{{- $sshCommand := "ssh" -}}

{{- if eq .chezmoi.os "windows" -}}
    {{- $program = "C:/Program Files/1Password/app/8/op-ssh-sign.exe" -}}
    {{- $allowedSignersFile = printf "%s/.ssh/allowed_signers" $windowsHome -}}
    {{- $excludesFile = printf "%s/.gitignore" $windowsHome -}}
    {{- $sshCommand = "C:/Windows/System32/OpenSSH/ssh.exe" -}}
{{- else if and (eq .chezmoi.os "linux") (contains "microsoft" (.chezmoi.kernel | toString)) -}}
    {{- $program = "/mnt/c/Program Files/1Password/app/8/op-ssh-sign-wsl" -}}
    {{- $allowedSignersFile = printf "/mnt/c/Users/%s/.ssh/allowed_signers" $username -}}
    {{- $sshCommand = "ssh.exe" -}}
{{- else if eq .chezmoi.os "android" -}}
    {{- $program = "ssh-keygen" -}}
    {{- $sshCommand = "ssh" -}}
{{- end -}}

{{- /* Default user fields from 1Password Active SSHs (notes-based) */ -}}
{{- $defaultUsername := "" -}}
{{- $defaultUserEmail := "" -}}
{{- $defaultUserSigningkey := "" -}}
{{- warnf "[gitconfig] fetching Active SSHs..." -}}
{{- $activeSsh := onepassword "Active SSHs" "personal" "my" -}}
{{- $sshNotes := "" -}}
{{- range $activeSsh.fields -}}
  {{- if and (eq .label "notesPlain") (hasKey . "value") -}}
    {{- $sshNotes = .value -}}
  {{- end -}}
{{- end -}}
{{- range splitList "\n" $sshNotes -}}
  {{- $title := . | trim -}}
  {{- if ne $title "" -}}
    {{- $parts := split "@" $title -}}
    {{- $device := index $parts "_0" -}}
    {{- warnf "[gitconfig] checking \"%s\"" $title -}}
    {{- if eq $device $deviceName -}}
      {{- warnf "[gitconfig] matched \"%s\" for SSH defaults" $title -}}
      {{- $item := onepassword $title "Private" "my" -}}
      {{- $f := dict -}}
      {{- range $item.fields -}}
        {{- if hasKey . "value" -}}
          {{- $_ := set $f .label .value -}}
        {{- end -}}
      {{- end -}}
      {{- $defaultUsername = index $f "ssh username" -}}
      {{- $defaultUserEmail = index $f "ssh email" -}}
      {{- $defaultUserSigningkey = index $f "public key" -}}
      {{- break -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

[user]
    name = "{{ $defaultUsername }}"
    email = "{{ $defaultUserEmail }}"
    signingkey = "{{ $defaultUserSigningkey }}"
[gpg]
    format = ssh
[gpg "ssh"]
    program = "{{ $program }}"
    allowedSignersFile = "{{ $allowedSignersFile }}"
[commit]
    gpgsign = true
[tag]
    forceSignAnnotated = true
[alias]
    pom = push origin main -u
    cim = "!f() { git commit -m \"$*\"; }; f"
    ci = commit
    co = checkout
    cm = checkout main
    cb = checkout -b
    st = status -sb
    sf = show --name-only
    lg = log --pretty=format:'%Cred%h%Creset %C(bold)%cr%Creset %Cgreen<%an>%Creset %s' --max-count=30
    incoming = !(git fetch --quiet && git log --pretty=format:'%C(yellow)%h %C(white)- %C(red)%an %C(white)- %C(cyan)%d%Creset %s %C(white)- %ar%Creset' ..@{u})
    outgoing = !(git fetch --quiet && git log --pretty=format:'%C(yellow)%h %C(white)- %C(red)%an %C(white)- %C(cyan)%d%Creset %s %C(white)- %ar%Creset' @{u}..)
    unstage = reset HEAD --
    undo = checkout --
    rollback = reset --soft HEAD~1

    # gpg signing
{{- template "op-gpg-gitconfig-aliases" . }}

    # ssh signing
{{- template "op-ssh-gitconfig-aliases" . }}
[core]
    autocrlf = input
    editor = vim
    excludesfile = "{{ $excludesFile }}"
    sshCommand = "{{ $sshCommand }}"
[merge]
    commit = yes
    ff = yes
[push]
    autoSetupRemote = true

