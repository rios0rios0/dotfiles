{{- $deviceName := .deviceName -}}

{{- warnf “[authorized-keys] fetching Active SSHs...” -}}
{{- range (onepassword “Active SSHs” “personal” “my”).fields -}}
  {{- if (eq .type “REFERENCE”) -}}

    {{- $parts := split “@” .label -}}
    {{- $device := index $parts “_0” -}}

    {{- if eq $device $deviceName -}}
      {{- warnf “[authorized-keys] matched \”%s\”” .label -}}
      {{- $item := onepassword .value “Private” “my” -}}

      {{- $f := dict -}}
      {{- range $item.fields -}}
        {{- if hasKey . “value” -}}
          {{- $_ := set $f .label .value -}}
        {{- end -}}
      {{- end -}}
      {{- printf “%s\n” (index $f “public key”) -}}

    {{- end -}}
  {{- end -}}
{{- end }}
